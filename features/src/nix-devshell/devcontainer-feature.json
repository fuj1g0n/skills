{
  "id": "nix-devshell",
  "version": "0.0.1",
  "name": "Nix flake devShell (single-user, create-time install) [PoC]",
  "description": "PoC: installs upstream Nix in single-user mode at container-create time into a /nix named volume, with direnv + nix-direnv + nil + nixfmt, per fuj1g0n/skills ADR-0010..0015.",
  "documentationURL": "https://github.com/fuj1g0n/skills",
  "mounts": [
    {
      "source": "nix-store-${devcontainerId}",
      "target": "/nix",
      "type": "volume"
    }
  ],
  "onCreateCommand": "bash /usr/local/share/nix-devshell/setup.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "direnv.restart.automatic": true,
        "nix.enableLanguageServer": true,
        "nix.serverPath": "nil",
        "nix.serverSettings": {
          "nil": {
            "formatting": {
              "command": ["nixfmt"]
            }
          }
        }
      },
      "extensions": ["jnoortheen.nix-ide", "mkhl.direnv"]
    }
  },
  "installsAfter": ["ghcr.io/devcontainers/features/common-utils"]
}
